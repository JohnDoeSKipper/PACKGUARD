# PackGuard v2.0 — environment variables
#
# Copy to .env and fill in. .env is gitignored.
#
#   cp .env.example .env
#   $EDITOR .env

# ── Anthropic (required for /orchestrate endpoints) ──────────────────────────
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional model override. Default = claude-opus-4-7
# Other valid values: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
PACKGUARD_MODEL=claude-opus-4-7

# ── Service ports (override only if you need to) ─────────────────────────────
# PIPELINE_PORT=8001
# ORCHESTRATOR_PORT=8002
# UI_PORT=3000

# ── Cross-service URLs (Orchestrator → Pipeline) ─────────────────────────────
# PIPELINE_URL=http://localhost:8001
