# ─────────────────────────────────────────────────────────────────────────────
### Full orchestration — REQUIRES ANTHROPIC_API_KEY in .env
### This calls Claude to write the narrative (temperature=0)
POST {{baseUrl}}/orchestrate
Content-Type: application/json

{
  "lot_id": "LOT-EARLY-KILL-DEMO",
  "package_type": "BGA-256",
  "target_application": "automotive",
  "overall_decision": "kill",
  "metadata": {"wafer_id": "W-2026-042"},
  "checkpoints": [
    {"step": 1, "name": "dicing", "decision": "kill", "reasons": ["Crack 2.1mm > 1.5mm JEDEC limit", "Survival simulator: fracture at reflow"], "cost_avoided": 1847.0, "skipped": false, "cv_invoked": false, "cv_confidence": null, "physics_outputs": {"probability_of_failure": 0.94, "confidence_interval": [0.88, 0.98], "predicted_lifetime": 0.3, "units": "probability", "model_used": "Griffith Crack Propagation", "assumptions": ["SAC305 solder"], "failure_mode": "die_crack_propagation", "process_sigma_drift": 0.5, "cv_detects_defect": null}},
