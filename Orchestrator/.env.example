# PackGuard — Environment Variables
# Copy this file to .env and fill in your values.
# VS Code will load this automatically via launch.json envFile settings.
# NEVER commit the real .env to git.

# ── Required for LLM narrative generation ─────────────────────────────────────
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-PASTE-YOUR-KEY-HERE

# ── Optional server settings ──────────────────────────────────────────────────
# PORT=8001
# HOST=0.0.0.0

# ── Optional: override PDF output directory ───────────────────────────────────
# PDF_OUTPUT_DIR=/tmp
